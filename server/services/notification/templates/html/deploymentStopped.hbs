<div class="badge warning-badge">⏹️ Deployment Stopped</div>

<h1 class="title">Deployment Stopped</h1>
<p class="subtitle">Your deployment for <strong>{{projectName}}</strong> has been stopped and is no longer running.</p>

<div class="feature-list">
  <h3>Deployment Details</h3>
  <ul>
    <li><strong>Project:</strong> {{projectName}}</li>
    <li><strong>Environment:</strong> {{environment}}</li>
    <li><strong>Stopped:</strong> {{timestamp}}</li>
    <li><strong>Reason:</strong> {{reason}}</li>
    {{#if commitHash}}
    <li><strong>Last Commit:</strong> {{commitHash}}</li>
    {{/if}}
  </ul>
</div>

<p style="color: #a3a3a3; margin: 24px 0; font-size: 14px;">
  You can restart the deployment anytime from your project dashboard. All your configuration and settings have been preserved.
</p>

{{#if dashboardUrl}}
{{> button url=dashboardUrl label="Go to Project Dashboard"}}
{{/if}}

{{#if logsUrl}}
<p style="color: #737373; margin: 24px 0 0 0; font-size: 14px; text-align: center;">
  <a href="{{logsUrl}}" class="text-link">View Deployment Logs</a> • 
  <a href="mailto:support@deployio.tech" class="text-link">Contact Support</a>
</p>
{{/if}}
