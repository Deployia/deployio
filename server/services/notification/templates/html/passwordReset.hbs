<div class="badge">🔑 Password Reset</div>
<h2 class="title">Reset Your Password</h2>
<p class="subtitle">You requested a password reset for your DeployIO account.</p>

<div class="highlight-box">
  <p style="margin: 0 0 16px 0; color: #ffffff; font-weight: 600;">Click the
    button below to reset your password:</p>
  {{#if resetLink}}
    <a href="{{resetLink}}" class="cta">Reset Password</a>
  {{/if}}
  <p style="margin: 16px 0 0 0; color: #a1a1aa; font-size: 14px;">This link
    expires in
    {{expiresIn}}</p>
</div>

<div class="security-info">
  <strong>Security Notes:</strong>
  <ul style="margin: 8px 0 0 0; padding-left: 20px;">
    <li>This link can only be used once</li>
    <li>If you didn't request this reset, ignore this email</li>
    <li>Your password remains unchanged until you create a new one</li>
  </ul>
</div>

<p style="color: #71717a; font-size: 14px; margin: 16px 0 0 0;">
  For security reasons, if you need another reset link, please request a new one
  from the login page.
</p>