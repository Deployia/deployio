<div class="badge success-badge">✅ Deployment Success</div>

<h1 class="title">Deployment Successful!</h1>
<p class="subtitle">Great news! Your deployment for <strong>{{projectName}}</strong> has completed successfully and is now live.</p>

<div class="feature-list">
  <h3>Deployment Details</h3>
  <ul>
    <li><strong>Project:</strong> {{projectName}}</li>
    <li><strong>Environment:</strong> {{environment}}</li>
    <li><strong>Completed:</strong> {{timestamp}}</li>
    {{#if duration}}
    <li><strong>Duration:</strong> {{duration}}</li>
    {{/if}}
    {{#if commitHash}}
    <li><strong>Commit:</strong> {{commitHash}}</li>
    {{/if}}
  </ul>
</div>

<p style="color: #a3a3a3; margin: 24px 0; font-size: 14px;">
  Your application is now live and accessible to users. All health checks have passed and your deployment is ready to serve traffic.
</p>

{{#if deploymentUrl}}
{{> button url=deploymentUrl label="View Live Application"}}
{{/if}}

{{#if dashboardUrl}}
<p style="color: #737373; margin: 24px 0 0 0; font-size: 14px; text-align: center;">
  <a href="{{dashboardUrl}}" class="text-link">View in Dashboard</a> • 
  <a href="{{logsUrl}}" class="text-link">View Logs</a>
</p>
{{/if}}
