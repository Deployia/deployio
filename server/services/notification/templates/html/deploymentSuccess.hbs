{{> brand}}
<div class="badge">✅ Deployment Success</div>
<div class="main-title">Deployment Successful!</div>
<div class="subtitle">Great news! Your deployment for {{projectName}} has completed successfully.</div>
<div class="card">
  <h3 style="color:#22d3ee;margin-bottom:8px;font-family:'Space Grotesk',sans-serif;font-size:1.2rem;">Deployment Details</h3>
  <ul style="color:#a3a3a3;font-size:1rem;">
    <li>Project: {{projectName}}</li>
    <li>Environment: {{environment}}</li>
    <li>Completed: {{timestamp}}</li>
    {{#if duration}}
      <li>Duration: {{duration}}</li>
    {{/if}}
  </ul>
</div>
<p>Your application is now live and accessible to users.</p>
{{#if deploymentUrl}}
  {{> button url=deploymentUrl label="View Live Application"}}
{{/if}}
