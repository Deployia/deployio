<div class="badge error-badge">🚨 Security Alert</div>

<h1 class="title">Security Alert: {{securityAction}}</h1>
<p class="subtitle">A security-related change was made to your DeployIO account.</p>

<div class="feature-list">
  <h3>Security Event Details</h3>
  <ul>
    <li><strong>Action:</strong> {{securityAction}}</li>
    <li><strong>Time:</strong> {{timestamp}}</li>
    <li><strong>Device:</strong> {{device}}</li>
    <li><strong>Location:</strong> {{location}}</li>
    <li><strong>IP Address:</strong> {{ipAddress}}</li>
  </ul>
</div>

<div class="security-info">
  <strong>Security Notice:</strong> If this wasn't you, please secure your account immediately by changing your password, enabling two-factor authentication, and reviewing your account security settings.
</div>

{{#if securityUrl}}
{{> button url=securityUrl label="Review Account Security"}}
{{/if}}

<p style="color: #737373; margin: 24px 0 0 0; font-size: 14px; text-align: center;">
  <a href="mailto:support@deployio.tech" class="text-link">Report Security Issue</a> • 
  <a href="https://deployio.tech/security" class="text-link">Security Help Center</a>
</p>
