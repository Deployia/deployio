<div class="badge">� Email Verification</div>
<h2 class="title">Verify Your Account</h2>
<p class="subtitle">Enter this verification code to complete your account setup:</p>

<div class="highlight-box">
  <div class="code">{{otp}}</div>
  <p style="margin: 8px 0 0 0; color: #a1a1aa; font-size: 14px;">Expires in
    {{expiresIn}}</p>
</div>

{{#if actionUrl}}
  <a href="{{actionUrl}}" class="cta">Verify Account</a>
{{/if}}

<div class="security-info">
  <strong>Security Note:</strong>
  Never share this code with anyone. DeployIO will never ask for your
  verification code.
</div>

<p style="color: #71717a; font-size: 14px; margin: 16px 0 0 0;">
  If you didn't request this code, you can safely ignore this email.
</p>