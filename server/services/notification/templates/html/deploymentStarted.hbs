<div class="badge">🚀 Deployment Started</div>

<h1 class="title">Deployment Started</h1>
<p class="subtitle">Your deployment for <strong>{{projectName}}</strong> has started successfully and is now in progress.</p>

<div class="feature-list">
  <h3>Deployment Details</h3>
  <ul>
    <li><strong>Project:</strong> {{projectName}}</li>
    <li><strong>Environment:</strong> {{environment}}</li>
    <li><strong>Started:</strong> {{timestamp}}</li>
    {{#if commitHash}}
    <li><strong>Commit:</strong> {{commitHash}}</li>
    {{/if}}
    {{#if estimatedDuration}}
    <li><strong>Estimated Duration:</strong> {{estimatedDuration}}</li>
    {{/if}}
  </ul>
</div>

<p style="color: #a3a3a3; margin: 24px 0; font-size: 14px;">
  We're building and deploying your application. You'll receive another notification once the deployment is complete.
</p>

{{#if deploymentUrl}}
{{> button url=deploymentUrl label="View Deployment Progress"}}
{{/if}}

{{#if dashboardUrl}}
<p style="color: #737373; margin: 24px 0 0 0; font-size: 14px; text-align: center;">
  <a href="{{dashboardUrl}}" class="text-link">View in Dashboard</a> • 
  <a href="{{logsUrl}}" class="text-link">View Live Logs</a>
</p>
{{/if}}
