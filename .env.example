# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/mern-template?retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=example_super_secure_jwt_secret_9f8e7c6b5a4d3
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_IN=1
JWT_REFRESH_SECRET=example_refresh_secret_1a2b3c4d5e6f7g8h
JWT_REFRESH_EXPIRES_IN=7d

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Frontend URLs
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://yourproductionurl.com

# Email Configuration for Nodemailer
EMAIL_SERVICE=gmail
EMAIL_FROM=your_email@gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Password Reset Token Expiry (in minutes)
PASSWORD_RESET_EXPIRES=30

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
