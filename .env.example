# DeployIO Platform Configuration
# This is the main configuration file for the entire platform

# ===========================================
# PLATFORM CONFIGURATION
# ===========================================

# Platform Environment
NODE_ENV=development
PLATFORM_VERSION=1.0.0

# ===========================================
# SERVICE CONFIGURATION
# ===========================================

# Server Configuration (Express Backend)
SERVER_PORT=3000
SERVER_ENV=development

# Client Configuration (Frontend)
CLIENT_PORT=5173
CLIENT_ENV=development

# AI Service Configuration (FastAPI)
AI_SERVICE_PORT=8000
AI_SERVICE_ENV=development

# Deployment Agent Configuration
AGENT_PORT=9000
AGENT_ENV=development

# ===========================================
# DOCKER COMPOSE CONFIGURATION
# ===========================================

# Production image registry
ECR_REGISTRY=533266971626.dkr.ecr.ap-south-1.amazonaws.com

# Service image tags
FRONTEND_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest
AI_SERVICE_IMAGE_TAG=latest

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================

# Development URLs
VITE_API_URL=http://localhost:3000
VITE_AI_SERVICE_URL=http://localhost:8000

# Development flags
ENABLE_DEBUG=true
ENABLE_HOT_RELOAD=true

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Health check intervals
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3

# Logging configuration
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# NOTES
# ===========================================
# - Copy this file to .env and configure your values
# - Each service has its own .env file in its directory
# - This file contains platform-wide configuration
# - Service-specific configs are in their respective folders
