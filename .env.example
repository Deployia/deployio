
# MongoDB Connection String
MONGODB_URI=mongodb://mongodb:27017/deployio

# JWT Secret Key
JWT_SECRET=example_super_secure_jwt_secret_9f8e7c6b5a4d3c2b1a0f9e8d7c6b5a4
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_IN=1
JWT_REFRESH_SECRET=example_refresh_secret_1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
JWT_REFRESH_EXPIRES_IN=7d

# Application Environment: development or production
NODE_ENV=development

# Server Port
PORT=3000

# Frontend URLs
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://deployio.tech

# Email Configuration for Nodemailer
EMAIL_SERVICE=gmail
EMAIL_FROM=your_email@gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Password Reset Token Expiry (in minutes)
PASSWORD_RESET_EXPIRES=30

# OAuth and External Services (replace with your credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
