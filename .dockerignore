# Root .dockerignore for DeployIO Platform
# This covers the entire monorepo

# Dependencies
**/node_modules/
**/package-lock.json
**/.pnp
**/.pnp.js

# Environment files
**/.env
**/.env.*.local
**/.env.production

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Runtime data
**/pids
**/*.pid
**/*.seed
**/*.pid.lock

# Coverage directory used by tools like istanbul
**/coverage/
**/.nyc_output

# Build outputs
**/build/
**/dist/
**/.next/
**/out/

# Development files
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Docker
**/Dockerfile
**/docker-compose*.yml

# Python
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
**/.Python
**/venv/
**/ENV/
**/env/
**/.venv/

# Jupyter Notebook
**/.ipynb_checkpoints

# Documentation
**/docs/
**/README.md

# Development and testing
**/dev/
**/tests/
**/.pytest_cache/

# SSL certificates
**/letsencrypt/
**/*.pem
**/*.key
**/*.crt

# Temporary files
**/tmp/
**/temp/
