# DeployIO Agent Environment Configuration

# App Configuration
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# Domain Configuration
BASE_DOMAIN=deployio.tech
WILDCARD_SSL_ENABLED=true

# Authentication & Security
AGENT_SECRET=your-secure-agent-secret-change-this
SECRET_KEY=your-very-secure-secret-key-here-change-this

# Platform Communication
PLATFORM_URL=https://deployio.tech
PLATFORM_API_KEY=your_platform_api_key_here

# Database Configuration (MongoDB Atlas)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/deployio_agent?retryWrites=true&w=majority
MONGODB_DATABASE=deployio_agent

# Docker Configuration
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=deployio-network

# ECR Configuration
AWS_REGION=us-east-1
ECR_REGISTRY_URL=your-account-id.dkr.ecr.us-east-1.amazonaws.com

# Traefik Configuration
TRAEFIK_API_URL=http://traefik:8080
TRAEFIK_CONFIG_DIR=/dynamic

# Resource Limits (per user container)
MAX_MEMORY=256m
MAX_CPU=0.25
MAX_STORAGE=1g

# SSL/TLS Configuration
ACME_EMAIL=admin@deployio.tech

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
# Generate new password: htpasswd -nb admin yourpassword
TRAEFIK_AUTH_USERS=admin:$$2y$$10$$8K1p.ytjBV6k2C5k6H4cLe7YvOq1M8QfZtYP4v8YVxF0Q1Y3k8W5C

# Deployment Configuration
MAX_CONCURRENT_DEPLOYMENTS=5
DEPLOYMENT_TIMEOUT=600

# CORS Configuration (comma-separated)
CORS_ORIGINS=https://deployio.tech,https://agent.deployio.tech,https://app.deployio.tech
