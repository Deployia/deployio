# DeployIO Agent Environment Configuration

# App Configuration
DEBUG=false
ENVIRONMENT=production

# Domain Configuration
BASE_DOMAIN=deployio.tech
WILDCARD_SSL_ENABLED=true

# Cloudflare Configuration (Required for wildcard SSL)
CLOUDFLARE_EMAIL=your-cloudflare-email@example.com
CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-dns-api-token

# Authentication
AGENT_SECRET=your-secure-agent-secret-change-this
SECRET_KEY=your-very-secure-secret-key-here-change-this

# Database Configuration
DATABASE_URL=sqlite:///./agent.db

# MongoDB Configuration (no auth required - internal only)
MONGODB_DATABASE=deployio_agent

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Traefik Dashboard Basic Auth (generated with htpasswd)
# Default: admin/admin (change this!)
# Generate new password: htpasswd -nb admin yourpassword
TRAEFIK_AUTH_USERS=admin:$$2y$$10$$8K1p.ytjBV6k2C5k6H4cLe7YvOq1M8QfZtYP4v8YVxF0Q1Y3k8W5C

# Deployment Configuration
MAX_CONCURRENT_DEPLOYMENTS=5
DEPLOYMENT_TIMEOUT=600

# CORS Configuration (comma-separated)
CORS_ORIGINS=https://deployio.tech,https://agent.deployio.tech,https://app.deployio.tech
