# DeployIO Agent Environment Configuration

# App Configuration
DEBUG=false
ENVIRONMENT=production

# Domain Configuration
BASE_DOMAIN=deployio.tech
WILDCARD_SSL_ENABLED=false

# Authentication
AGENT_SECRET=your-secure-agent-secret-change-this

# MongoDB Configuration (no auth required - internal only)
MONGODB_DATABASE=deployio_agent

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Deployment Configuration
MAX_CONCURRENT_DEPLOYMENTS=5
DEPLOYMENT_TIMEOUT=600

# CORS Configuration (comma-separated)
CORS_ORIGINS=https://deployio.tech,https://agent.deployio.tech,https://app.deployio.tech
