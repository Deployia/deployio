# =============================================================================
# DEPLOYIO AGENT - EXAMPLE ENVIRONMENT
# =============================================================================

# Core runtime
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# Authentication
AGENT_SECRET=development-secret-change-in-production
API_KEY_HEADER=X-Agent-Secret

# Platform communication (internal Docker network)
PLATFORM_URL=http://backend:3000
PLATFORM_API_KEY=

# Agent identity and bridge
AGENT_ID=agent-production-1
LOG_BRIDGE_ENABLED=true
LOG_BRIDGE_RECONNECT_ATTEMPTS=10
LOG_BRIDGE_RECONNECT_DELAY=5
LOG_BRIDGE_BUFFER_SIZE=1000
LOG_BRIDGE_BATCH_SIZE=50
LOG_BRIDGE_FLUSH_INTERVAL=5

# Docker integration
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=web

# Resource and rate limits
MAX_MEMORY=256m
MAX_CPU=0.25
MAX_STORAGE=1g
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging and health
LOG_LEVEL=info
LOG_FORMAT=json
HEALTH_CHECK_INTERVAL=30
HEARTBEAT_INTERVAL=60

# Optional deployment config
BASE_DOMAIN=deployio.tech
WILDCARD_SSL_ENABLED=false
MAX_CONCURRENT_DEPLOYMENTS=5
DEPLOYMENT_TIMEOUT=600
