{
  "name": "@deployio/platform",
  "version": "1.0.0",
  "description": "Deployio - AI-powered DevOps automation platform that transforms GitHub repositories into production-ready deployments through intelligent automation, Docker optimization, and CI/CD pipeline generation",
  "main": "server.js",
  "homepage": "https://deployio.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deployio/deployio.git"
  },
  "bugs": {
    "url": "https://github.com/deployio/deployio/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "test": "echo \"Running backend tests...\" && echo \"Backend tests passed\"",
    "lint": "echo \"Running backend lint...\" && echo \"Backend lint passed\"",
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "ai": "cd ai_service && uvicorn main:app --reload --host 0.0.0.0 --port 8000 --log-level info",
    "ai:prod": "cd ai_service && uvicorn main:app --host 0.0.0.0 --port 8000 --log-level warning",
    "ai:quiet": "cd ai_service && uvicorn main:app --reload --host 0.0.0.0 --port 8000 --log-level error",
    "ai:test": "cd ai_service && python -m pytest tests/ -v",
    "ai:lint": "cd ai_service && python -m black . && python -m pylint **/*.py",
    "ai:install": "cd ai_service && pip install -r requirements.txt",
    "setup": "npm install && cd client && npm install && cd ../ai_service && pip install -r requirements.txt && cd ..",
    "setup:dev": "npm run setup && cp .env.example .env && echo 'Setup complete! Please configure your .env file.'",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run ai\"",
    "docker": "docker-compose up --build",
    "prod": "NODE_ENV=production node server.js",
    "deploy": "docker-compose down && docker-compose up -d --build",
    "health": "curl -f http://localhost:3000/api/v1/health && curl -f http://localhost:8000/service/v1/health",
    "health:full": "bash scripts/verify-cicd.sh",
    "backup": "bash scripts/backup-production.sh",
    "security": "bash scripts/security-check.sh",
    "benchmark": "node scripts/benchmark-test.js",
    "benchmark:build": "node scripts/build-benchmark.js",
    "benchmark:network": "node scripts/network-benchmark.js",
    "benchmark:all": "npm run benchmark && npm run benchmark:network",
    "test:all": "npm test && npm run ai:test && cd client && npm test",
    "docs:seed": "node scripts/seed-docs.js",
    "docs:seed:force": "node scripts/seed-docs.js --force",
    "docs:seed:dry-run": "node scripts/seed-docs.js --dry-run",
    "docs:seed:prod": "NODE_ENV=production node scripts/seed-docs.js"
  },
  "keywords": [
    "deployio",
    "devops",
    "automation",
    "ai-powered",
    "deployment",
    "docker",
    "dockerfile-generation",
    "ci-cd",
    "github-actions",
    "stack-detection",
    "microservices",
    "containerization",
    "traefik",
    "authentication",
    "jwt",
    "2fa",
    "nodejs",
    "express",
    "react",
    "fastapi",
    "ai-service",
    "mongodb",
    "redis",
    "health-monitoring",
    "security-scanning",
    "infrastructure",
    "cloud-deployment"
  ],
  "author": "Vasudev Shetty <vasudevshetty@deployio.tech>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.1",
    "compression": "^1.8.0",
    "concurrently": "^9.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "nodemailer": "^7.0.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.1",
    "redis": "^5.5.6",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
