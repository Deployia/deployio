# Platform-level .gitignore for DeployIO

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production
.env.staging

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server/logs/*.log
ai-service/logs/*.log
agent/logs/*.log

# Metrics files
server/logs/metrics/*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
.dockerignore

# Platform specific
temp/
*.tmp

# Build artifacts
dist/
build/

# SSL certificates
*.pem
*.key
*.crt

# Backup files
*.backup
*.bak
