# DeployIO AI Service - Multi-Stack Analysis & Config Generation
# FastAPI Service Environment Variables

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# DEPLOYIO PLATFORM INTEGRATION
# =============================================================================
# Main DeployIO Service URLs
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://deployio.tech
PRODUCTION_URL=https://deployio.tech

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your_internal_service_token_here
DEPLOYIO_API_KEY=your_deployio_api_key_here

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
CACHE_ENABLED=true

# =============================================================================
# AI & LLM CONFIGURATION
# =============================================================================
# LLM API Keys (At least one required)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Settings
LLM_CONFIDENCE_THRESHOLD=0.75
LLM_MAX_RETRIES=3
LLM_TIMEOUT=30
LLM_MODEL_GROQ=llama3-70b-8192
LLM_MODEL_OPENAI=gpt-4-turbo-preview

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# GitHub API Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: public_repo, read:org
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_URL=https://api.github.com
GITHUB_RATE_LIMIT=5000

# =============================================================================
# ANALYSIS CONFIGURATION
# =============================================================================
# Repository Analysis Settings
MAX_CONCURRENT_REQUESTS=10
ANALYSIS_TIMEOUT=300
MAX_REPOSITORY_SIZE_MB=500
MAX_FILE_COUNT=10000

# Technology Stack Detection
SUPPORTED_LANGUAGES=javascript,typescript,python,java,go,php,ruby,csharp,rust,kotlin,swift,dart
SUPPORTED_FRAMEWORKS=react,vue,angular,express,nextjs,fastapi,django,spring,gin,laravel,rails,dotnet,flutter

# Security & Quality Analysis
SECURITY_SCAN_ENABLED=true
CODE_QUALITY_ANALYSIS=true
DEPENDENCY_VULNERABILITY_CHECK=true
COMPLEXITY_THRESHOLD=10

# =============================================================================
# CONFIGURATION GENERATION
# =============================================================================
# Docker Configuration
DOCKER_OPTIMIZATION=true
MULTI_STAGE_BUILDS=true
SECURITY_SCANNING=true

# CI/CD Pipeline Generation
CICD_PLATFORMS=github-actions,gitlab-ci,jenkins
DEFAULT_CICD_PLATFORM=github-actions

# Kubernetes & Orchestration
KUBERNETES_CONFIGS=true
DOCKER_COMPOSE_CONFIGS=true
HELM_CHARTS=false

# =============================================================================
# PERFORMANCE & SECURITY
# =============================================================================
# API Performance
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_REQUEST_SIZE=10MB
REQUEST_TIMEOUT=60

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://deployio.tech

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Application Monitoring
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
STRUCTURED_LOGGING=true

# External Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
DATADOG_API_KEY=your_datadog_key_here

# =============================================================================
# FEATURE FLAGS - MULTI-STACK SUPPORT
# =============================================================================
# Primary Stack Support (Production Ready)
ENABLE_NODEJS_ANALYSIS=true
ENABLE_PYTHON_ANALYSIS=true
ENABLE_JAVA_ANALYSIS=true
ENABLE_GO_ANALYSIS=true
ENABLE_PHP_ANALYSIS=true
ENABLE_DOTNET_ANALYSIS=true
ENABLE_RUBY_ANALYSIS=true
ENABLE_RUST_ANALYSIS=true

# Frontend Frameworks
ENABLE_REACT_ANALYSIS=true
ENABLE_NEXTJS_ANALYSIS=true
ENABLE_VUE_ANALYSIS=true
ENABLE_ANGULAR_ANALYSIS=true
ENABLE_SVELTE_ANALYSIS=true

# Mobile & Cross-Platform
ENABLE_FLUTTER_ANALYSIS=true
ENABLE_REACT_NATIVE_ANALYSIS=true
ENABLE_SWIFT_ANALYSIS=false
ENABLE_KOTLIN_ANALYSIS=true

# Emerging Technologies (Future Support)
ENABLE_DART_ANALYSIS=false
ENABLE_SCALA_ANALYSIS=false
ENABLE_ELIXIR_ANALYSIS=false

