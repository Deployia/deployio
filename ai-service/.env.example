# DeployIO AI Service - Multi-Stack Analysis & Config Generation
# FastAPI Service Environment Variables

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# DEPLOYIO PLATFORM INTEGRATION
# =============================================================================
# Main DeployIO Service URLs
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://deployio.tech
PRODUCTION_URL=https://deployio.tech

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your_internal_service_token_here
DEPLOYIO_API_KEY=your_deployio_api_key_here

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
CACHE_ENABLED=true

# =============================================================================
# AI & LLM CONFIGURATION
# =============================================================================
# LLM API Keys (At least one required)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Settings
LLM_CONFIDENCE_THRESHOLD=0.75
LLM_MAX_RETRIES=3
LLM_TIMEOUT=30
LLM_MODEL_GROQ=llama3-70b-8192
LLM_MODEL_OPENAI=gpt-4-turbo-preview

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# GitHub API Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: public_repo, read:org
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_URL=https://api.github.com
GITHUB_RATE_LIMIT=5000


# =============================================================================
# PERFORMANCE & SECURITY
# =============================================================================
# API Performance
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_REQUEST_SIZE=10MB
REQUEST_TIMEOUT=60

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://deployio.tech

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Application Monitoring
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
STRUCTURED_LOGGING=true

# External Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
DATADOG_API_KEY=your_datadog_key_here
